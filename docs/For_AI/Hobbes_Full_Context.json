        "fallback_logic": "path.resolve(process.cwd(), '..')",
        "caveat": "Correct when app cwd is dashboard-mvp; risky if launched from an unexpected cwd without HOBBES_CONTROL_ROOT."
      }
    },
    "runtime_sync": {
      "code_path": "dashboard-mvp/lib/runtime-sync.ts",
      "modes": [
        "direct_ssh",
        "queued_worker_fallback"
      ],
      "direct_ssh_requires_env": [
        "HOBBES_VPS_HOST",
        "HOBBES_VPS_USER",
        "HOBBES_VPS_PASSWORD"
      ],
      "queued_worker_requires_env_on_vps": [
        "HOBBES_CONTROL_BASE_URL",
        "HOBBES_CONTROL_TOKEN"
      ],
      "target_files_to_remote_paths": {
        "config/telegram/chat_policies.example.json": "/home/hobbes/.openclaw/policies/chat_policies.json",
        "config/telegram/behavior_profiles.example.json": "/home/hobbes/.openclaw/policies/behavior_profiles.json",
        "config/agents/main/workspace/PERSONAS.md": "/home/hobbes/.openclaw/workspace-main/PERSONAS.md",
        "config/agents/main/workspace/REMINDERS.md": "/home/hobbes/.openclaw/workspace-main/REMINDERS.md",
        "config/agents/chief/workspace/REMINDERS.md": "/home/hobbes/.openclaw/workspace-chief/REMINDERS.md",
        "config/agents/chief/workspace/MEETING_PREP.md": "/home/hobbes/.openclaw/workspace-chief/MEETING_PREP.md",
        "config/agents/chief/workspace/DOCUMENT_SHAPES.md": "/home/hobbes/.openclaw/workspace-chief/DOCUMENT_SHAPES.md",
        "config/agents/comms/workspace/PERSONAS.md": "/home/hobbes/.openclaw/workspace-comms/PERSONAS.md",
        "config/agents/comms/workspace/DOCUMENT_SHAPES.md": "/home/hobbes/.openclaw/workspace-comms/DOCUMENT_SHAPES.md"
      },
      "post_sync_hooks": {
        "telegram_policy_files": [
          "python3 /usr/local/bin/compile-telegram-group-policies.py"
        ]
      },
      "authoritative_success_gate": "systemctl --user is-active openclaw-gateway.service",
      "nuance": "Queued worker intentionally treats active systemd state as success even if HTTP health is not yet ready."
    },
    "ingest_pipeline": {
      "sender_script": "scripts/remote/hobbes_dashboard_snapshot.sh",
      "auth_header": "x-ingest-token",
      "event_schema_support": true,
      "overview_snapshot_support": true,
      "current_real_usage": [
        "Overview snapshots are live",
        "Full event telemetry is partial",
        "Usage/cost/approvals are placeholders or incomplete"
      ]
    }
  },
  "api_routes": [
    {
      "path": "/api/health",
      "method": "GET",
      "auth": "none",
      "purpose": "Simple health response for dashboard service",
      "response_shape": {
        "ok": true,
        "service": "hobbes-dashboard-mvp"
      }
    },
    {
      "path": "/api/overview",
      "method": "GET",
      "auth": "none",
      "purpose": "Return latest overview snapshot",
      "backing_logic": "Select latest row from dashboard_snapshots; fallback to mock data if DB missing or empty",
      "cache_control": "no-store"
    },
    {
      "path": "/api/ingest",
      "method": "POST",
      "auth": "x-ingest-token must equal INGEST_TOKEN",
      "purpose": [
        "Insert overview snapshots",
        "Insert operational events"
      ],
      "snapshot_type_supported": "overview_snapshot",
      "event_type_supported": true,
      "failure_modes": [
        "unauthorized",
        "invalid_payload",
        "database_not_configured"
      ]
    },
    {
      "path": "/api/control/files",
      "method": "GET",
      "auth": "none",
      "purpose": "List allowlisted control files and their availability"
    },
    {
      "path": "/api/control/file",
      "method": "GET",
      "auth": "none",
      "query_params": [
        "path"
      ],
      "purpose": "Read one allowlisted control file",
      "failure_modes": [
        "missing_path",
        "file_not_allowed"
      ]
    },
    {
      "path": "/api/control/history",
      "method": "GET",
      "auth": "none",
      "query_params": [
        "path"
      ],
      "purpose": "Read GitHub history for one allowlisted file",
      "failure_modes": [
        "missing_path",
        "file_not_allowed"
      ]
    },
    {
      "path": "/api/control/draft",
      "method": "POST",
      "auth": "none",
      "body_keys": [
        "path",
        "content",
        "kind"
      ],
      "purpose": "Validate and save draft in control_drafts",
      "failure_modes": [
        "invalid_payload",
        "file_not_allowed",
        "validation_failed",
        "database_not_configured"
      ]
    },
    {
      "path": "/api/control/apply-repo",
      "method": "POST",
      "auth": "none",
      "body_keys": [
        "path",
        "content"
      ],
      "purpose": "Validate and write allowlisted file to GitHub repo",
      "failure_modes": [
        "invalid_payload",
        "file_not_allowed",
        "apply_failed",
        "github_control_not_configured"
      ]
    },
    {
      "path": "/api/control/sync-runtime",
      "method": "POST",
      "auth": "none",
      "body_keys": [
        "path"
      ],
      "purpose": "Sync allowlisted repo_and_runtime file to VPS",
      "modes": {
        "direct": "SSH upload + optional compiler hook + gateway restart + health checks",
        "queued": "Fallback if direct SSH handshake times out"
      },
      "fallback_trigger": "error message contains 'Timed out while waiting for handshake'",
      "failure_modes": [
        "invalid_payload",
        "file_not_allowed",
        "runtime_sync_failed"
      ]
    },
    {
      "path": "/api/control/runtime-sync/claim",
      "method": "POST",
      "auth": "Authorization: Bearer <INGEST_TOKEN>",
      "purpose": "Worker claims next pending runtime sync job",
      "failure_modes": [
        "unauthorized"
      ]
    },
    {
      "path": "/api/control/runtime-sync/complete",
      "method": "POST",
      "auth": "Authorization: Bearer <INGEST_TOKEN>",
      "body_keys": [
        "id",
        "status",
        "lastError"
      ],
      "purpose": "Worker marks queued runtime sync job as applied or failed",
      "allowed_status_values": [
        "applied",
        "failed"
      ],
      "failure_modes": [
        "unauthorized",
        "invalid_payload"
      ]
    }
  ],
  "db_schema_summary": {
    "client_config": {
      "library": "postgres_js",
      "prepare": false,
      "max_connections": 5,
      "idle_timeout_seconds": 10,
      "url_resolution_order": [
        "DATABASE_URL",
        "DATABASE_PRIVATE_URL"
      ]
    },
    "tables": {
      "dashboard_snapshots": {
        "primary_key": "id",
        "columns": [
          "id BIGSERIAL",
          "source TEXT",
          "captured_at TIMESTAMPTZ",
          "summary JSONB",
          "agents JSONB",
          "runs JSONB",
          "events JSONB",
          "searches JSONB default []",
          "created_at TIMESTAMPTZ default now()"
        ],
        "indexes": [
          "dashboard_snapshots_captured_at_idx on captured_at desc"
        ],
        "role": "Primary latest-state source for overview screen"
      },
      "dashboard_events": {
        "primary_key": "id",
        "columns": [
          "id BIGSERIAL",
          "source TEXT",
          "event_type TEXT",
          "agent_id TEXT nullable",
          "run_id TEXT nullable",
          "severity TEXT",
          "event_ts TIMESTAMPTZ",
          "payload JSONB",
          "created_at TIMESTAMPTZ default now()"
        ],
        "indexes": [
          "dashboard_events_event_ts_idx on event_ts desc"
        ],
        "role": "Operational event log, but current product usage is still partial"
      },
      "control_drafts": {
        "primary_key": "id",
        "uniqueness": [
          "file_path unique"
        ],
        "columns": [
          "id BIGSERIAL",
          "file_path TEXT unique",
          "content_type TEXT",
          "content TEXT",
          "updated_at TIMESTAMPTZ default now()",
          "created_at TIMESTAMPTZ default now()"
        ],
        "indexes": [
          "control_drafts_updated_at_idx on updated_at desc"
        ],
        "role": "Stored drafts per allowlisted file"
      },
      "control_runtime_sync_jobs": {
        "primary_key": "id",
        "columns": [
          "id BIGSERIAL",
          "file_path TEXT",
          "remote_path TEXT",
          "content TEXT",
          "status TEXT default pending",
          "created_at TIMESTAMPTZ default now()",
          "claimed_at TIMESTAMPTZ nullable",
          "applied_at TIMESTAMPTZ nullable",
          "updated_at TIMESTAMPTZ default now()",
          "last_error TEXT nullable"
        ],
        "indexes": [
          "control_runtime_sync_jobs_status_created_at_idx on (status, created_at asc)"
        ],
        "statuses": [
          "pending",
          "in_progress",
          "applied",
          "failed"
        ],
        "queue_logic": [
          "claim uses FOR UPDATE SKIP LOCKED",
          "oldest pending job is claimed first"
        ],
        "role": "Fallback queue when Railway cannot finish direct SSH runtime sync"
      }
    }
  },
  "timing_and_consistency": {
    "configured_intervals": {
      "snapshot_timer_seconds": 120,
      "snapshot_health_probe_timeout_seconds": 3,
      "snapshot_log_tail_lines": 200,
      "queued_sync_on_boot_seconds": 30,
      "queued_sync_poll_interval_seconds": 60,
      "worker_http_timeout_seconds": 30,
      "direct_sync_health_probe_attempts": 6,
      "direct_sync_health_probe_sleep_seconds": 2,
      "direct_sync_total_health_window_seconds": 12
    },
    "inferred_consistency_windows": {
      "dashboard_overview_freshness": {
        "min_seconds": 0,
        "max_seconds": 180,
        "inferred": true,
        "reason": "Snapshot timer is 120s; add script execution, ingest, and DB read lag."
      },
      "queued_runtime_sync_latency": {
        "min_seconds": 30,
        "max_seconds": 120,
        "inferred": true,
        "reason": "Worker can wait until next 60s poll and then still needs file apply + restart time."
      },
      "direct_sync_false_negative_risk": {
        "inferred": true,
        "reason": "HTTP health may still fail during the first seconds after restart even when systemd already reports active."
      }
    },
    "user_visible_implications": [
      "Dashboard can show a healthy but slightly stale overview.",
      "Queued runtime sync is not immediate even when functioning correctly.",
      "Systemd-active is currently a stronger runtime-sync success signal than HTTP health."
    ]
  },
  "operational_nuances": [
    "Overview UI reads only the latest snapshot row, not a reconstructed live graph from normalized run tables.",
    "Dashboard falls back to mock overview data when DATABASE_URL is missing or when no snapshot rows exist.",
    "Control Center validates Telegram behavior as a bundle: behavior_profiles + chat_policies + comms PERSONAS.",
    "Control Center syncs sourceContent from GitHub/filesystem; unsaved draftContent is not what gets pushed to runtime.",
    "Queued runtime sync job captures file content at enqueue time; later repo changes do not mutate that already-queued payload.",
    "Direct runtime sync uses password-based SSH from Railway-side code.",
    "Runtime sync queue worker uses INGEST_TOKEN as Bearer token against claim/complete endpoints.",
    "Snapshot sender intentionally filters logs toward operational signals and avoids full conversational content.",
    "Current dashboard snapshot sender publishes overview snapshots, not full structured multi-agent telemetry."
  ],
